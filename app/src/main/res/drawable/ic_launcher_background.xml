<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Gradient Deep Violet Background Canvas -->
    <path
        android:pathData="M 0,0 L 108,0 L 108,108 L 0,108 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="76">
                <item android:color="#4C1D95" android:offset="0.0" />
                <item android:color="#3A1061" android:offset="0.5" />
                <item android:color="#1A0D30" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Concentric Accent Rings matching the sporty look of the image -->
    <!-- Dark Inner Circular border (headphone outer ring) -->
    <path
        android:pathData="M 54,12 A 42,42 0 1,1 54,96 A 42,42 0 1,1 54,12"
        android:strokeWidth="4.0"
        android:strokeColor="#1E113A" />

    <!-- Thin white circle background ring wrapper -->
    <path
        android:pathData="M 54,15 A 39,39 0 1,1 54,93 A 39,39 0 1,1 54,15"
        android:strokeWidth="1.2"
        android:strokeColor="#50FFFFFF" />

    <!-- Left Sporty Panel (Pink / Coral Accent Arc) -->
    <path
        android:pathData="M 17,35 A 38,38 0 0,0 17,73"
        android:strokeWidth="3.5"
        android:strokeColor="#FF6B8B" />

    <!-- Right Sporty Panel (Pink / Coral Accent Arc) -->
    <path
        android:pathData="M 91,35 A 38,38 0 0,1 91,73"
        android:strokeWidth="3.5"
        android:strokeColor="#FF6B8B" />

    <!-- Bottom Accent Ribbon (Bright Violet Arc) -->
    <path
        android:pathData="M 33,88 A 38,38 0 0,0 75,88"
        android:strokeWidth="4.0"
        android:strokeColor="#7C3AED" />

</vector>
